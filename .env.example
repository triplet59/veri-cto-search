# Public — fine to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Server-side only — NEVER expose
SUPABASE_SERVICE_ROLE_KEY=eyJxxx
ANTHROPIC_API_KEY=sk-ant-xxx
RESEND_API_KEY=re_xxx

# Random secret used to authenticate the apply form's background screening trigger.
# Generate with: openssl rand -hex 32
# (or any long random string — never share it)
INTERNAL_API_TOKEN=replace-with-a-long-random-string

# Site URL for absolute links in emails
# Set to your Vercel-provided URL initially (e.g. https://veri-cto-search.vercel.app),
# swap to the custom Veri subdomain once DNS is configured.
NEXT_PUBLIC_SITE_URL=https://veri-cto-search.vercel.app

# Admin allow-list (comma-separated emails). Anyone else gets bounced from /admin.
ADMIN_EMAILS=derry@veri-global.com
